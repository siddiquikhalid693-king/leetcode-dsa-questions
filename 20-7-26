// Shift 2D Grid

import java.util.ArrayList;
import java.util.List;

class Solution {
    public List<List<Integer>> shiftGrid(int[][] grid, int k) {
        int m = grid.length;
        int n = grid[0].length;
        int totalElements = m * n;
        
        // Simplify shift operations
        int effectiveK = k % totalElements;
        
        // Initialize empty result grid
        List<List<Integer>> result = new ArrayList<>();
        for (int i = 0; i < m; i++) {
            result.add(new ArrayList<>(n));
            for (int j = 0; j < n; j++) {
                result.get(i).add(0);
            }
        }
        
        // Map elements to their new 2D positions
        for (int r = 0; r < m; r++) {
            for (int c = 0; c < n; c++) {
                int flatIdx = r * n + c;
                int newFlatIdx = (flatIdx + effectiveK) % totalElements;
                
                int newR = newFlatIdx / n;
                int newC = newFlatIdx % n;
                
                result.get(newR).set(newC, grid[r][c]);
            }
        }
        
        return result;
    }
}

