import java.util.*;

class Solution {
    public int minScore(int n, int[][] roads) {
        List<int[]>[] graph = new ArrayList[n + 1];

        for (int i = 1; i <= n; i++) {
            graph[i] = new ArrayList<>();
        }

        for (int[] road : roads) {
            int a = road[0];
            int b = road[1];
            int d = road[2];

            graph[a].add(new int[]{b, d});
            graph[b].add(new int[]{a, d});
        }

        boolean[] visited = new boolean[n + 1];
        Queue<Integer> q = new LinkedList<>();

        q.add(1);
        visited[1] = true;

        int ans = Integer.MAX_VALUE;

        while (!q.isEmpty()) {
            int city = q.poll();

            for (int[] edge : graph[city]) {
                int next = edge[0];
                int dist = edge[1];

                ans = Math.min(ans, dist);

                if (!visited[next]) {
                    visited[next] = true;
                    q.add(next);
                }
            }
        }

        return ans;
    }
}
